{
  "name": "kioku",
  "version": "0.12.3",
  "description": "Application time tracker — know where your hours go",
  "author": "ItsAshn",
  "license": "UNLICENSED",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.3.9",
    "fastest-levenshtein": "^1.0.16",
    "fuse.js": "^7.0.0",
    "get-windows": "^9.0.0",
    "lucide-react": "^0.436.0",
    "ps-list": "^8.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.0",
    "sql.js": "^1.12.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "com.kioku.app",
    "productName": "KIOKU",
    "directories": {
      "buildResources": "resources"
    },
    "publish": {
      "provider": "github",
      "owner": "ItsAshn",
      "repo": "Kioku",
      "releaseType": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "linux": {
      "artifactName": "${productName}.${ext}",
      "executableName": "KIOKU",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons",
      "category": "Utility",
      "maintainer": "ItsAshn",
      "vendor": "ItsAshn",
      "synopsis": "Application time tracker",
      "description": "Track how much time you spend in each application",
      "desktop": {
        "Name": "KIOKU",
        "Comment": "Application time tracker — know where your hours go",
        "Categories": "Utility;Office;",
        "StartupWMClass": "KIOKU"
      }
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "esbuild",
      "get-windows"
    ]
  }
}
